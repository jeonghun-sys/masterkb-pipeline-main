{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "python -m pip install --upgrade pip && python -m pip install --no-cache-dir --target ./.railway-deps -r requirements.txt"
  },
  "deploy": {
    "startCommand": "sh -c 'PYTHONPATH=.railway-deps:src python -m uvicorn kb_pipeline.main:app --host 0.0.0.0 --port ${PORT:-8000}'",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
